# =============================================================================
# AgroNavis — Master Environment Configuration
# =============================================================================
# Copy this file to .env in the root directory.
# Both Frontend (Next.js) and Backend (FastAPI) will load from this single file.

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
# For local development, `supabase start` provides these exact values.
# They are identical for every developer. Do not change for local dev.
SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

SUPABASE_ANON_KEY=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

SUPABASE_SERVICE_ROLE_KEY=""

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
# Where the Python API runs
PORT=8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Where the Next.js Frontend runs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# LLM Configuration (Backend Only)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=""

# -----------------------------------------------------------------------------
# External APIs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WEATHER_API_KEY=your_openweathermap_api_key_here

# -----------------------------------------------------------------------------
# Development Bypass
# -----------------------------------------------------------------------------
# Local Dev-only auto login credentials (do not use in production)
# Run `supabase start` then `supabase db reset` to create this test user.
NEXT_PUBLIC_DEV_EMAIL=dev@agronavis.local
NEXT_PUBLIC_DEV_PASSWORD=change-this-to-your-local-dev-password
